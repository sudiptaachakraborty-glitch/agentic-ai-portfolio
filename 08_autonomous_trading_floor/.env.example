# Required
OPENAI_API_KEY=sk-...

# Required for market data — free tier at https://polygon.io
POLYGON_API_KEY=

# At least ONE of the following for web/news search:
BRAVE_API_KEY=
SERPER_API_KEY=

# Optional — alternative model providers (each trader can use a different LLM)
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=

# Optional — push notifications when a trader buys / sells
PUSHOVER_USER=
PUSHOVER_TOKEN=

# Loop control — set to a large number or leave high while demoing.
# The actual scheduler reads this from trading_floor.py.
RUN_EVERY_N_MINUTES=60
